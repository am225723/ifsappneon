VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_AUTHORIZED_PARTIES=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=IFS App

DATABASE_URL=postgresql://user:password@host/db?sslmode=require
VITE_DATA_API_PATH=/api/db

# Legacy SSO callback compatibility. This is frontend-visible because it is a VITE_* value.
# Do not put a real production secret here; prefer Clerk/server-side verification for production SSO.
VITE_JWT_SECRET=

# UploadThing v7 uses a single server-side token. Do not expose as VITE_*.
UPLOADTHING_TOKEN=ut_live_replace_me
UPLOADTHING_CALLBACK_URL=

# Legacy UploadThing variables retained only for older deployments; this app now prefers UPLOADTHING_TOKEN.
UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

ALLOW_PIN_AUTH_WITHOUT_CLERK=false
