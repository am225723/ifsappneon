# Clerk authentication
# Create these in Clerk Dashboard > API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Optional comma-separated domains/origins for Clerk JWT verification.
# Example: https://ifs.yourdomain.com,http://localhost:5173
CLERK_AUTHORIZED_PARTIES=

# OpenAI session prep summaries
# Configure server-side only in Vercel; do not expose as VITE_OPENAI_API_KEY.
OPENAI_API_KEY=sk_replace_me

# Neon Postgres
# Use the pooled Neon connection string for Vercel/serverless.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Frontend data bridge. Keep /api/db on Vercel unless you move the serverless API.
VITE_DATA_API_PATH=/api/db

# UploadThing
UPLOADTHING_APP_ID=replace_me
UPLOADTHING_SECRET=sk_live_replace_me
UPLOADTHING_CALLBACK_URL=

# Security switch
# Keep false in production so all /api/db requests require a valid Clerk bearer token.
# Only set true briefly during controlled migration/debugging.
ALLOW_PIN_AUTH_WITHOUT_CLERK=false
